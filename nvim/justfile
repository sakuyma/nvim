# Dotfiles Installer Justfile
# Run commands with: just <command>
# List all commands: just --list

set shell := ["bash", "-c"]
set dotenv-load := true

# Default command (show help)
default:
    @just --list

count:
    @echo "Line count: "
    @find -name "*.lua" -exec wc -l {} + | tail -1
    @echo ""
    @echo "By module: "
    @find -name "*.lua" -exec wc -l {} + | sort -rn

# Show help
help:
    @just --list
